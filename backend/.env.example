# TalentNation Backend Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# Database (PostgreSQL for production)
# Local: file:./dev.db (SQLite)
# Production: postgresql://user:pass@host:5432/dbname
# ============================================
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/talentnation"

# ============================================
# Redis (Optional for local, required for production)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# JWT Secrets (Generate with: openssl rand -base64 32)
# ============================================
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-change-in-production"

# ============================================
# Frontend URL (for CORS)
# ============================================
FRONTEND_URL="http://localhost:3000"

# ============================================
# Stripe Configuration (Test Mode)
# Get from: https://dashboard.stripe.com/test/apikeys
# ============================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================
# Email Configuration (Gmail SMTP example)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL="noreply@talentnation.sa"

# ============================================
# Google OAuth (Optional)
# Get from: https://console.cloud.google.com/apis/credentials
# ============================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# AWS S3 (Optional - for file uploads)
# ============================================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="me-south-1"
AWS_S3_BUCKET="talentnation-uploads"

# ============================================
# Logging
# ============================================
LOG_LEVEL="debug"
